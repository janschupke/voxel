#Overlay {
    flex-grow: 1;
    /* flex-direction: column-reverse; */
    /* align-items: center; */
    /* position: relative; */
}

#TopPanel {
    flex-grow: 0;
    flex-shrink: 0;
    min-height: 15px;
    height: 15px;
    background-color: rgba(0, 0, 0, 0.7);
}

#CentralContainer {
    flex-grow: 1;
    flex-direction: row-reverse;
}

#Sidebar {
    flex-grow: 0;
    flex-shrink: 0;
    flex-direction: column;
    background-color: rgba(0, 0, 0, 0.7);
}

#SelectionDetail {
    flex-direction: column;
    padding-top: 10px;
}

#SelectionName {
    color: white;
    font-size: 10px;
    padding-bottom: 5px;
}

#FPS {
    /* flex-grow: 0;
    flex-shrink: 0; */
    /* position: absolute;
    top: 10px;
    left: 10px; */
    color: white;
    font-size: 10px;
    padding-left: 2px;
}

Button {
    width: 70px;
    background-color: rgba(0, 0, 0, 0.7);
    color: white;
    border-radius: 10px;
    padding: 5px;
    font-size: 10px;
}

Button:hover {
    background-color: rgba(0, 0, 0, 0.9);
}

Button.placing {
    background-color: rgba(0, 100, 0, 0.7);
}

.hidden {
    display: none;
}
